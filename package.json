{
  "name": "drupal-sdc-starter",
  "version": "0.1.0",
  "description": "Reusable Drupal starter theme using Single Directory Components, Storybook and Bootstrap.",
  "private": true,
  "author": "Taylor Spaven",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "npm run lint:scss && npm run lint:js",
    "lint:scss": "stylelint \"theme/**/*.scss\"",
    "lint:js": "eslint theme/**/*.js",
    "css:build": "sass --style=expanded --no-source-map theme/scss/global.scss theme/css/global.css",
    "css:dev": "sass --style=expanded --source-map theme/scss/global.scss theme/css/global.css",
    "css:watch": "sass --watch --style=expanded --source-map theme/scss/global.scss:theme/css/global.css"
  },
  "devDependencies": {
    "sass": "^1.101.0"
  }
}
